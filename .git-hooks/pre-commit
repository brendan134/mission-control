#!/bin/bash
# Enhanced Pre-Commit Hook
# Blocks problematic files before commit

echo "Running pre-commit checks..."

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Change to workspace root
cd /data/.openclaw/workspace 2>/dev/null || cd "$(git rev-parse --show-toplevel)"

# Track if we should abort
ABORT=0

# ============================================
# CHECK 1: Files with spaces
# ============================================
echo "Checking for files with spaces..."
FILES_WITH_SPACES=$(git diff --cached --name-only | grep ' ' || true)
if [ -n "$FILES_WITH_SPACES" ]; then
    echo -e "${RED}❌ BLOCKED: Files with spaces detected:${NC}"
    echo "$FILES_WITH_SPACES" | sed 's/^/  - /'
    echo -e "${RED}Use kebab-case or camelCase instead of spaces${NC}"
    ABORT=1
fi

# ============================================
# CHECK 2: Common typo directories
# ============================================
echo "Checking for typo directories..."
TYPOS="ISSION"
TYPEDIRS=$(git diff --cached --name-only | grep -E "^${TYPOS}" || true)
if [ -n "$TYPEDIRS" ]; then
    echo -e "${RED}❌ BLOCKED: Typo directory detected (should be MISSION):${NC}"
    echo "$TYPEDIRS" | sed 's/^/  - /'
    ABORT=1
fi

# Check for temp_ directories
TEMP_DIRS=$(git diff --cached --name-only | grep -E "^temp_" || true)
if [ -n "$TEMP_DIRS" ]; then
    echo -e "${RED}❌ BLOCKED: temp_ directories not allowed:${NC}"
    echo "$TEMP_DIRS" | sed 's/^/  - /'
    ABORT=1
fi

# Check for workspace- directories (duplicates)
WORKSPACE_DUPS=$(git diff --cached --name-only | grep -E "^workspace-" || true)
if [ -n "$WORKSPACE_DUPS" ]; then
    echo -e "${RED}❌ BLOCKED: Duplicate workspace directories detected:${NC}"
    echo "$WORKSPACE_DUPS" | sed 's/^/  - /'
    ABORT=1
fi

# Check for mission- directories (incomplete names)
MISSION_DUPS=$(git diff --cached --name-only | grep -E "^mission-" | grep -v "^mission-control" || true)
if [ -n "$MISSION_DUPS" ]; then
    echo -e "${RED}❌ BLOCKED: Duplicate mission directories detected:${NC}"
    echo "$MISSION_DUPS" | sed 's/^/  - /'
    ABORT=1
fi

# ============================================
# CHECK 3: Sensitive files
# ============================================
echo "Checking for sensitive files..."
SENSITIVE=$(git diff --cached --name-only | grep -E '\.(env|credentials|pem|key)$' || true)
if [ -n "$SENSITIVE" ]; then
    echo -e "${RED}❌ BLOCKED: Sensitive files detected:${NC}"
    echo "$SENSITIVE" | sed 's/^/  - /'
    ABORT=1
fi

# ============================================
# CHECK 4: Duplicate src at root
# ============================================
echo "Checking for duplicate src..."
DUPLICATE_SRC=$(git diff --cached --name-only | grep -E "^src/" | grep -v "^mission-control/src/" || true)
if [ -n "$DUPLICATE_SRC" ]; then
    echo -e "${RED}❌ BLOCKED: Duplicate src at root (use mission-control/src only):${NC}"
    echo "$DUPLICATE_SRC" | sed 's/^/  - /'
    ABORT=1
fi

# ============================================
# CHECK 5: Empty files
# ============================================
echo "Checking for empty files..."
EMPTY_FILES=$(git diff --cached --name-only -s | grep -E "\.(json|md|txt)$" | while read f; do
    if [ ! -s "$f" ]; then
        echo "$f"
    fi
done)
if [ -n "$EMPTY_FILES" ]; then
    echo -e "${YELLOW}⚠️ WARNING: Empty files detected:${NC}"
    echo "$EMPTY_FILES" | sed 's/^/  - /'
    echo -e "${YELLOW}Consider removing empty files before committing${NC}"
fi

# ============================================
# CHECK 6: Verify canonical structure
# ============================================
echo "Checking canonical directories..."
CANONICAL="mission-control memory business content packs curriculum podcast projects workflows templates context scripts skills"
for dir in $CANONICAL; do
    CHECK=$(git diff --cached --name-only | grep -E "^${dir}/" | head -1)
    if [ -n "$CHECK" ]; then
        :
        # Canonical directory present - OK
    fi
done

# ============================================
# Final Result
# ============================================
if [ $ABORT -eq 1 ]; then
    echo ""
    echo -e "${RED}=========================================="
    echo -e "COMMIT BLOCKED - Fix issues above"
    echo -e "==========================================${NC}"
    exit 1
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0