'use client';
import { useState, useEffect } from 'react';
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, Line, ComposedChart } from 'recharts';
import { CreditCard, Users, Clock, Zap, Activity, TrendingUp, AlertCircle, Shield, Check, X } from 'lucide-react';

interface Issue {
  id: string;
  title: string;
  description: string;
  whyItMatters: string;
  fixCommand: string;
  securityImpact: string;
  severity: 'critical' | 'warn' | 'info';
  fixed: boolean;
  skipped: boolean;
}

export default function Dashboard() {
  const [stats, setStats] = useState({
    todaySpend: 0,
    monthSpend: 0,
    budget: 100,
    messages: 0,
    agents: 1,
    gatewayStatus: 'online',
    loading: true,
  });
  const [spendData, setSpendData] = useState<any>(null);
  const [modelView, setModelView] = useState<'month' | 'year'>('month');
  const [systemCheckRunning, setSystemCheckRunning] = useState(false);
  const [issues, setIssues] = useState<Issue[]>([]);
  const [showIssues, setShowIssues] = useState(false);
  const [fixing, setFixing] = useState<string | null>(null);
  const [costAuditRunning, setCostAuditRunning] = useState(false);
  const [costAuditResult, setCostAuditResult] = useState<string | null>(null);
  const [costRecommendations, setCostRecommendations] = useState<Issue[]>([]);
  const [showCostRecommendations, setShowCostRecommendations] = useState(false);

  useEffect(() => {
    fetch('/api/stats')
      .then(res => res.json())
      .then(data => setStats({ ...data, loading: false }))
      .catch(() => setStats(s => ({ ...s, loading: false })));
  }, []);

  useEffect(() => {
    fetch('/api/spend')
      .then(res => res.json())
      .then(data => setSpendData(data))
      .catch(() => {});
  }, []);

  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'USD' }).format(amount);
  };

  const runSystemCheck = async () => {
    setSystemCheckRunning(true);
    setIssues([]);
    setShowIssues(false);
    
    try {
      // Run both checks
      const [healthRes, securityRes] = await Promise.all([
        fetch('/api/actions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'health-check' })
        }),
        fetch('/api/actions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'security-audit' })
        })
      ]);
      
      const healthData = await healthRes.json();
      const securityData = await securityRes.json();
      
      const healthOutput = healthData.output || '';
      const securityOutput = securityData.output || '';
      
      // Parse issues
      const foundIssues: Issue[] = [];
      
      // Health check issues
      if (healthOutput.includes('NODE_COMPILE_CACHE') || healthOutput.includes('OPENCLAW_NO_RESPAWN')) {
        foundIssues.push({
          id: 'startup-performance', title: 'Startup Performance', description: 'NODE_COMPILE_CACHE and OPENCLAW_NO_RESPAWN not set',
          whyItMatters: 'CLI commands run slower on small hosts (Pi/VM)', fixCommand: 'echo "export NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache" >> ~/.bashrc',
          securityImpact: 'None - performance only', severity: 'warn', fixed: false, skipped: false
        });
      }
      if (healthOutput.includes('whatsapp') && healthOutput.includes('disabled')) {
        foundIssues.push({
          id: 'whatsapp-warning', title: 'WhatsApp Config Warning', description: 'WhatsApp plugin disabled but config present',
          whyItMatters: 'Shows warning on every health check', fixCommand: 'Delete plugins.entries.whatsapp from config',
          securityImpact: 'None - cleanup only', severity: 'info', fixed: false, skipped: false
        });
      }
      if (healthOutput.includes('first-time setup') || healthOutput.includes('pairing mode')) {
        foundIssues.push({
          id: 'telegram-pairing', title: 'Telegram Pairing Mode', description: 'Telegram in pairing mode - new DMs need approval',
          whyItMatters: 'New senders blocked, group messages stopped', fixCommand: 'Change dmPolicy to "open" (security warning: run security audit first)',
          securityImpact: 'WARNING: May affect security - review in security audit', severity: 'warn', fixed: false, skipped: false
        });
      }
      
      // Security issues
      if (securityOutput.includes('CRITICAL') || securityOutput.includes('groupPolicy="open"')) {
        foundIssues.push({
          id: 'open-group-critical', title: 'Open Group Policy (CRITICAL)', description: 'groupPolicy="open" with elevated tools',
          whyItMatters: 'Prompt injection in open groups can execute dangerous commands', fixCommand: 'Change groupPolicy to "allowlist"',
          securityImpact: 'SECURITY FIX - Essential', severity: 'critical', fixed: false, skipped: false
        });
      }
      if (securityOutput.includes('trusted_proxies')) {
        foundIssues.push({
          id: 'trusted-proxies', title: 'Trusted Proxies Missing', description: 'gateway.trustedProxies not configured',
          whyItMatters: 'Local checks can be spoofed if using reverse proxy', fixCommand: 'Set gateway.trustedProxies (only if using reverse proxy)',
          securityImpact: 'None for local-only setup', severity: 'warn', fixed: false, skipped: false
        });
      }
      
      setIssues(foundIssues);
      if (foundIssues.length > 0) {
        setShowIssues(true);
      }
    } catch (err: any) {
      console.error(err);
    } finally {
      setSystemCheckRunning(false);
    }
  };

  const fixIssue = async (issueId: string) => {
    const issue = issues.find(i => i.id === issueId);
    if (!issue || !issue.fixCommand) return;
    
    setFixing(issueId);
    try {
      const res = await fetch('/api/actions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'run-command', command: issue.fixCommand })
      });
      
      setIssues(issues.map(i => i.id === issueId ? { ...i, fixed: true } : i));
    } catch (err: any) {
      console.error(err);
    } finally {
      setFixing(null);
    }
  };

  const skipIssue = (issueId: string) => {
    setIssues(issues.map(i => i.id === issueId ? { ...i, skipped: true } : i));
  };

  const fixAll = async () => {
    for (const issue of issues) {
      if (!issue.fixed && !issue.skipped && issue.severity !== 'critical') {
        await fixIssue(issue.id);
      }
    }
  };

  const fixCostRecommendation = async (recId: string) => {
    const rec = costRecommendations.find(r => r.id === recId);
    if (!rec) return;
    
    try {
      if (rec.fixCommand.startsWith('openclaw')) {
        await fetch('/api/actions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'run-command', command: rec.fixCommand })
        });
      }
      setCostRecommendations(costRecommendations.map(r => r.id === recId ? { ...r, fixed: true } : r));
    } catch (err) {
      console.error(err);
    }
  };

  const runCostAudit = async () => {
    setCostAuditRunning(true);
    setCostAuditResult(null);
    setCostRecommendations([]);
    setShowCostRecommendations(false);
    try {
      const res = await fetch('/api/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'cost-audit' })
      });
      const data = await res.json();
      setCostAuditResult(data.output || data.error);
      
      // Parse recommendations from the report
      const recommendations: Issue[] = [];
      // Always add default recommendations
      recommendations.push({
        id: 'monthly-review', title: 'Schedule Monthly Cost Reviews', 
        description: 'Run this audit monthly to track spending patterns and optimize costs',
        whyItMatters: 'Regular reviews prevent cost creep and ensure system efficiency',
        fixCommand: 'openclaw cron add --name "Monthly Cost Review" --cron "0 7 1 * *" --tz "Australia/Brisbane" --system-event "Monthly cost review reminder" --session main --announce --to 8637899728',
        securityImpact: 'None - adds useful cron job with Telegram notification',
        severity: 'info', fixed: false, skipped: false
      });
      recommendations.push({
        id: 'model-strategy', title: 'Implement Model Selection Strategy',
        description: 'Use cheap models (minimax/flashlite) for simple tasks, premium (kimi/sonnet) for client work',
        whyItMatters: 'Can reduce costs by 50-80% while maintaining quality for client deliverables',
        fixCommand: 'openclaw config patch agents.defaults.model minimax',
        securityImpact: 'None - config change only',
        severity: 'warn', fixed: false, skipped: false
      });
      recommendations.push({
        id: 'cron-efficiency', title: 'Review Cron Job Frequency',
        description: 'Audit scheduled tasks and reduce frequency where possible',
        whyItMatters: 'Reduces unnecessary API calls and costs',
        fixCommand: 'openclaw cron list',
        securityImpact: 'None - displays cron jobs for manual review',
        severity: 'info', fixed: false, skipped: false
      });
      const output = data.output || '';
      
      if (output.includes('MODEL SELECTION STRATEGY')) {
        recommendations.push({
          id: 'model-strategy', title: 'Implement Model Selection Strategy',
          description: 'Use cheap models (minimax/flashlite) for simple tasks, premium (kimi/sonnet) for client work',
          whyItMatters: 'Can reduce costs by 50-80% while maintaining quality for client deliverables',
          fixCommand: 'openclaw config patch agents.defaults.model minimax',
          securityImpact: 'None - config change only',
          severity: 'warn', fixed: false, skipped: false
        });
      }
      
      if (output.includes('CRON JOB EFFICIENCY')) {
        recommendations.push({
          id: 'cron-efficiency', title: 'Review Cron Job Frequency',
          description: 'Audit scheduled tasks and reduce frequency where possible',
          whyItMatters: 'Reduces unnecessary API calls and costs',
          fixCommand: 'echo "Review cron jobs manually in Cron Calendar"',
          securityImpact: 'None - review task',
          severity: 'info', fixed: false, skipped: false
        });
      }
      
      if (output.includes('AGENT UTILIZATION')) {
        recommendations.push({
          id: 'agent-audit', title: 'Audit Active Agents',
          description: 'Review which agents are actively used and remove unused ones',
          whyItMatters: 'Simplifies system and reduces potential attack surface',
          fixCommand: 'openclaw agents list',
          securityImpact: 'None - review task',
          severity: 'info', fixed: false, skipped: false
        });
      }
      
      if (output.includes('BATCH CONTENT CREATION')) {
        recommendations.push({
          id: 'batch-content', title: 'Batch Content Creation',
          description: 'Combine related content tasks into single sessions',
          whyItMatters: 'Reduces per-request overhead and improves efficiency',
          fixCommand: 'echo "Plan content batching in weekly schedule"',
          securityImpact: 'None - process improvement',
          severity: 'info', fixed: false, skipped: false
        });
      }
      
      if (recommendations.length >= 0) {
        setCostRecommendations(recommendations);
        setShowCostRecommendations(true);
      }
    } catch (err: any) {
      setCostAuditResult(err.message);
    } finally {
      setCostAuditRunning(false);
    }
  };

  if (stats.loading) {
    return (
      <div style={{ padding: '32px', textAlign: 'center', color: 'var(--text-muted)' }}>
        Loading stats...
      </div>
    );
  }

  return (
    <div style={{ padding: '32px' }}>
      {/* Header */}
      <div style={{ marginBottom: '32px' }}>
        <h1 style={{ fontSize: '24px', fontWeight: 600, marginBottom: '4px' }}>Dashboard</h1>
        <p style={{ color: 'var(--text-secondary)', fontSize: '14px' }}>Your AI system at a glance</p>
      </div>

      {/* Stats Grid */}
      <div style={{ 
        display: 'grid', 
        gridTemplateColumns: 'repeat(4, 1fr)', 
        gap: '16px',
        marginBottom: '32px'
      }}>
        {/* Today's Spend */}
        <div className="card">
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '12px' }}>
            <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Today's Spend</span>
            <CreditCard size={16} style={{ color: 'var(--text-muted)' }} />
          </div>
          <div style={{ fontSize: '28px', fontWeight: 600 }}>{formatCurrency(stats.todaySpend)}</div>
          <div style={{ fontSize: '12px', color: stats.todaySpend > 4 ? '#ef4444' : 'var(--success)', marginTop: '4px' }}>{stats.todaySpend > 4 ? 'Over budget' : 'Within budget'}</div>
        </div>

        {/* Monthly Spend */}
        <div className="card">
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '12px' }}>
            <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Monthly Spend</span>
            <TrendingUp size={16} style={{ color: 'var(--text-muted)' }} />
          </div>
          <div style={{ fontSize: '28px', fontWeight: 600 }}>{formatCurrency(stats.monthSpend)}</div>
          <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginTop: '4px' }}>of {formatCurrency(stats.budget)} budget</div>
        </div>

        {/* Messages */}
        <div className="card">
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '12px' }}>
            <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Messages Today</span>
            <Activity size={16} style={{ color: 'var(--text-muted)' }} />
          </div>
          <div style={{ fontSize: '28px', fontWeight: 600 }}>{stats.messages}</div>
          <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginTop: '4px' }}>Active sessions</div>
        </div>

        {/* Active Agents */}
        <div className="card">
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '12px' }}>
            <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Active Agents</span>
            <Users size={16} style={{ color: 'var(--text-muted)' }} />
          </div>
          <div style={{ fontSize: '28px', fontWeight: 600 }}>{stats.agents}</div>
          <div style={{ fontSize: '12px', color: stats.gatewayStatus === 'online' ? 'var(--success)' : '#ef4444', marginTop: '4px' }}>
            {stats.gatewayStatus === 'online' ? 'All operational' : 'Issues detected'}
          </div>
        </div>
      </div>

      {/* Usage by Model */}
      {spendData && Object.keys(modelView === 'month' ? spendData.usageByModelMonth : spendData.usageByModelYear).length > 0 && (
        <div className="card" style={{ marginBottom: '24px' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '12px' }}>
            <h3 style={{ fontSize: '14px', fontWeight: 600, margin: 0 }}>Usage by Model</h3>
            <div style={{ display: 'flex', gap: '8px' }}>
              <button onClick={() => setModelView('month')} style={{ padding: '4px 8px', fontSize: '11px', borderRadius: '4px', border: modelView === 'month' ? '1px solid #3b82f6' : '1px solid #e5e7eb', background: modelView === 'month' ? '#dbeafe' : 'transparent', cursor: 'pointer' }}>Month</button>
              <button onClick={() => setModelView('year')} style={{ padding: '4px 8px', fontSize: '11px', borderRadius: '4px', border: modelView === 'year' ? '1px solid #3b82f6' : '1px solid #e5e7eb', background: modelView === 'year' ? '#dbeafe' : 'transparent', cursor: 'pointer' }}>Year</button>
            </div>
          </div>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(200px, 1fr))', gap: '12px' }}>
            {Object.entries(modelView === 'month' ? spendData.usageByModelMonth : spendData.usageByModelYear).map(([model, spend]) => (
              <div key={model} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '8px 12px', background: 'var(--background-tertiary)', borderRadius: '6px' }}>
                <span style={{ fontSize: '12px', fontWeight: 500 }}>{model.split('/').pop()}</span>
                <span style={{ fontSize: '13px', fontWeight: 600, color: '#3b82f6' }}>{formatCurrency(spend as number)}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Spend Charts Section */}
      {spendData && (
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px', marginTop: '24px' }}>
          {/* Daily Spend Chart */}
          <div className="card">
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
              <h3 style={{ fontSize: '14px', fontWeight: 600, margin: 0 }}>Daily Spend - This Month</h3>
            </div>
            <div style={{ height: '200px' }}>
              <ResponsiveContainer width="100%" height="100%">
                <ComposedChart data={spendData.daily}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f3f4f6" />
                  <XAxis dataKey="dayLabel" tick={{ fontSize: 10 }} stroke="#9ca3af" />
                  <YAxis tick={{ fontSize: 10 }} stroke="#9ca3af" tickFormatter={(v) => `$${v}`} />
                  <Tooltip 
                    formatter={(v: any) => `$${Number(v).toFixed(2)}`} 
                    contentStyle={{ borderRadius: '8px', border: '1px solid #e5e7eb', fontSize: '12px' }} 
                  />
                  <Bar dataKey="spend" fill="#3b82f6" radius={[4, 4, 0, 0]} />
                  <Line type="monotone" dataKey="spend" stroke="#ef44ff" strokeWidth={2} dot={false} name="Trend" />
                </ComposedChart>
              </ResponsiveContainer>
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginTop: '12px', fontSize: '12px' }}>
              <span style={{ color: 'var(--text-muted)' }}>Total: {formatCurrency(spendData.currentMonthTotal)}</span>
              <span style={{ color: spendData.dailyTrend >= 0 ? '#ef44ff' : '#22c55e', fontWeight: 500 }}>
                {spendData.dailyTrend >= 0 ? '↑' : '↓'} {formatCurrency(Math.abs(spendData.dailyTrend))}/day trend
              </span>
            </div>
          </div>

          {/* Monthly Spend Chart */}
          <div className="card">
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
              <h3 style={{ fontSize: '14px', fontWeight: 600, margin: 0 }}>Monthly Spend - 12 Months</h3>
            </div>
            <div style={{ height: '200px' }}>
              <ResponsiveContainer width="100%" height="100%">
                <ComposedChart data={spendData.monthly}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f3f4f6" />
                  <XAxis dataKey="label" tick={{ fontSize: 10 }} stroke="#9ca3af" />
                  <YAxis tick={{ fontSize: 10 }} stroke="#9ca3af" tickFormatter={(v) => `$${v}`} />
                  <Tooltip 
                    formatter={(v: any) => `$${Number(v).toFixed(2)}`} 
                    contentStyle={{ borderRadius: '8px', border: '1px solid #e5e7eb', fontSize: '12px' }} 
                  />
                  <Bar dataKey="spend" fill="#10b981" radius={[4, 4, 0, 0]} />
                  <Line type="monotone" dataKey="spend" stroke="#ef44ff" strokeWidth={2} dot={false} name="Trend" />
                </ComposedChart>
              </ResponsiveContainer>
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', marginTop: '12px', fontSize: '12px' }}>
              <span style={{ color: 'var(--text-muted)' }}>Year Total: {formatCurrency(spendData.yearTotal)}</span>
              <span style={{ color: spendData.monthlyTrend >= 0 ? '#ef44ff' : '#22c55e', fontWeight: 500 }}>
                {spendData.monthlyTrend >= 0 ? '↑' : '↓'} {formatCurrency(Math.abs(spendData.monthlyTrend))}/mo trend
              </span>
            </div>
          </div>
        </div>
      )}

      {/* Quick Actions & Recent Activity */}
      <div style={{ display: 'grid', gridTemplateColumns: '2fr 1fr', gap: '16px' }}>
        
        {/* Quick Actions */}
        <div className="card">
          <h3 style={{ fontSize: '14px', fontWeight: 600, marginBottom: '16px' }}>Quick Actions</h3>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '12px' }}>
            <button onClick={runCostAudit} disabled={costAuditRunning} className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              <Zap size={16} />
              {costAuditRunning ? 'Running...' : 'Run Cost Audit'}
            </button>
            <button className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              <Users size={16} />
              View Agents
            </button>
            <button className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              <Clock size={16} />
              Automations
            </button>
            <button onClick={runSystemCheck} disabled={systemCheckRunning} className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              <Shield size={16} />
              {systemCheckRunning ? 'Running System Check...' : 'System Check'}
            </button>
            <button className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              View Packs
            </button>
            <button className="btn btn-secondary" style={{ justifyContent: 'flex-start', padding: '12px' }}>
              Create QSGP
            </button>
          </div>
        </div>

        {/* Issues Review Section */}
        {showIssues && issues.length > 0 && (
          <div className="card" style={{ gridColumn: '1 / -1', marginTop: '16px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
              <h3 style={{ fontSize: '14px', fontWeight: 600, margin: 0 }}>Issues Found ({issues.filter(i => !i.fixed && !i.skipped).length})</h3>
              <button onClick={fixAll} className="btn btn-primary" style={{ padding: '8px 16px' }}>
                Fix All
              </button>
            </div>
            
            {issues.map(issue => (
              <div key={issue.id} style={{ 
                padding: '16px', 
                marginBottom: '12px', 
                background: issue.fixed ? '#d1fae5' : issue.skipped ? '#f3f4f6' : 'var(--background-tertiary)',
                borderRadius: '8px',
                borderLeft: `4px solid ${issue.severity === 'critical' ? '#ef4444' : issue.severity === 'warn' ? '#f59e0b' : '#6b7280'}`
              }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
                  <div>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '4px' }}>
                      <span style={{ 
                        fontSize: '11px', 
                        fontWeight: 600, 
                        padding: '2px 8px', 
                        borderRadius: '4px',
                        background: issue.severity === 'critical' ? '#ef4444' : issue.severity === 'warn' ? '#f59e0b' : '#6b7280',
                        color: 'white'
                      }}>
                        {issue.severity.toUpperCase()}
                      </span>
                      <span style={{ fontWeight: 600 }}>{issue.title}</span>
                    </div>
                    <div style={{ fontSize: '13px', color: 'var(--text-muted)', marginBottom: '8px' }}>{issue.description}</div>
                    <div style={{ fontSize: '12px', marginBottom: '4px' }}><strong>Why it matters:</strong> {issue.whyItMatters}</div>
                    {issue.securityImpact.includes('WARNING') && (
                      <div style={{ fontSize: '12px', color: '#f59e0b', fontWeight: 500, marginBottom: '4px' }}>{issue.securityImpact}</div>
                    )}
                    {issue.securityImpact.includes('SECURITY FIX') && (
                      <div style={{ fontSize: '12px', color: '#22c55e', fontWeight: 500, marginBottom: '4px' }}>{issue.securityImpact}</div>
                    )}
                    {issue.securityImpact === 'None' && (
                      <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginBottom: '4px' }}>{issue.securityImpact}</div>
                    )}
                  </div>
                  <div style={{ display: 'flex', gap: '8px' }}>
                    {issue.fixed ? (
                      <span style={{ color: '#22c55e', fontSize: '13px', display: 'flex', alignItems: 'center', gap: '4px' }}><Check size={14} /> Fixed</span>
                    ) : issue.skipped ? (
                      <span style={{ color: 'var(--text-muted)', fontSize: '13px', display: 'flex', alignItems: 'center', gap: '4px' }}><X size={14} /> Skipped</span>
                    ) : (
                      <>
                        <button onClick={() => fixIssue(issue.id)} disabled={fixing === issue.id} className="btn" style={{ padding: '6px 12px', fontSize: '12px' }}>
                          {fixing === issue.id ? 'Fixing...' : 'Fix'}
                        </button>
                        <button onClick={() => skipIssue(issue.id)} className="btn" style={{ padding: '6px 12px', fontSize: '12px' }}>
                          Skip
                        </button>
                      </>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {/* Cost Recommendations */}
        {costAuditResult && costRecommendations.length > 0 && (
          <div className="card" style={{ gridColumn: '1 / -1', marginTop: '16px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
              <h3 style={{ fontSize: '14px', fontWeight: 600, margin: 0 }}>💡 Recommendations ({costRecommendations.filter(r => !r.fixed && !r.skipped).length})</h3>
              <button onClick={() => {
                costRecommendations.forEach(r => {
                  if (!r.fixed && !r.skipped) fixCostRecommendation(r.id);
                });
              }} className="btn btn-primary" style={{ padding: '8px 16px' }}>
                Implement All
              </button>
            </div>
            
            {costRecommendations.map(rec => (
              <div key={rec.id} style={{ 
                padding: '16px', 
                marginBottom: '12px', 
                background: rec.fixed ? '#d1fae5' : rec.skipped ? '#f3f4f6' : 'var(--background-tertiary)',
                borderRadius: '8px',
                borderLeft: `4px solid ${rec.severity === 'warn' ? '#f59e0b' : '#6b7280'}`
              }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
                  <div>
                    <div style={{ fontWeight: 600, marginBottom: '4px' }}>{rec.title}</div>
                    <div style={{ fontSize: '13px', color: 'var(--text-muted)', marginBottom: '8px' }}>{rec.description}</div>
                    <div style={{ fontSize: '12px' }}><strong>Why:</strong> {rec.whyItMatters}</div>
                  </div>
                  <div style={{ display: 'flex', gap: '8px' }}>
                    {rec.fixed ? (
                      <span style={{ color: '#22c55e', fontSize: '13px', display: 'flex', alignItems: 'center', gap: '4px' }}><Check size={14} /> Done</span>
                    ) : rec.skipped ? (
                      <span style={{ color: 'var(--text-muted)', fontSize: '13px', display: 'flex', alignItems: 'center', gap: '4px' }}><X size={14} /> Skipped</span>
                    ) : (
                      <>
                        <button onClick={() => fixCostRecommendation(rec.id)} className="btn" style={{ padding: '6px 12px', fontSize: '12px' }}>
                          Implement
                        </button>
                        <button onClick={() => setCostRecommendations(costRecommendations.map(r => r.id === rec.id ? { ...r, skipped: true } : r))} className="btn" style={{ padding: '6px 12px', fontSize: '12px' }}>
                          Skip
                        </button>
                      </>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}


        {/* Cost Audit Result */}
        {costAuditResult && (
          <div className="card" style={{ gridColumn: '1 / -1', marginTop: '16px' }}>
            <h3 style={{ fontSize: '14px', fontWeight: 600, marginBottom: '12px', color: '#3b82f6' }}>Cost & System Audit</h3>
            <pre style={{ fontSize: '11px', whiteSpace: 'pre-wrap', background: 'var(--background-tertiary)', padding: '16px', borderRadius: '8px', maxHeight: '500px', overflow: 'auto', lineHeight: '1.5' }}>
              {costAuditResult}
            </pre>
          </div>
        )}
        {/* System Status */}
        <div className="card">
          <h3 style={{ fontSize: '14px', fontWeight: 600, marginBottom: '16px' }}>System Status</h3>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Gateway</span>
              <span className="badge badge-success">Online</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Cache</span>
              <span className="badge badge-success">Active</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Heartbeat</span>
              <span className="badge badge-success">Running</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <span style={{ fontSize: '13px', color: 'var(--text-secondary)' }}>Security</span>
              <span className="badge badge-success">Clean</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
