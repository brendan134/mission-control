import { NextRequest, NextResponse } from 'next/server';

// Stub function
function updateProjectStrategicAlignment(projectId: string, alignment: string) {
  return { success: true, projectId, alignment, message: 'Stub' };
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { projectId, alignment } = body;
    const result = updateProjectStrategicAlignment(projectId, alignment);
    return NextResponse.json(result);
  } catch (error) {
    const msg = error instanceof Error ? error.message : 'Unknown error';
    return NextResponse.json({ success: false, error: msg }, { status: 500 });
  }
}
